{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Originpay Docs",
  "colors": {
    "primary": "#5f44bb",
    "light": "#5f44bb",
    "dark": "#5f44bb"
  },
  "appearance": {
    "default": "light"
  },
  "favicon": "/logo/favicon.ico",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "icon": "box",
          "color": {
            "light": "#5f44bb",
            "dark": "#5f44bb"
          },
          "href": "https://merchant.originpay.in/dashboard"
        },
        {
          "anchor": "Feature Request",
          "icon": "slack",
          "href": "https://forms.gle/Mu57zYucCaUXf8YNA"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://www.originpay.in/blog"
        }
      ]
    },
    "versions": [
      {
        "version": "V1",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Get Started",
                "pages": [
                  "get-started/index",
                  "get-started/sandbox-vs-live-mode",
                  "get-started/api-authentication",
                  "get-started/rate-limits",
                  "get-started/error-codes"
                ]
              },
              {
                "group": "API Guide",
                "pages": [
                  "api-guide/create-order",
                  "api-guide/payment-request",
                  "api-guide/payment-link",
                  "api-guide/upi-intent",
                  "api-guide/payment-status",
                  "api-guide/webhook-callback"
                ]
              },
              {
                "group": "Android SDK",
                "pages": [
                  "android-sdk/introduction",
                  "android-sdk/installation",
                  "android-sdk/initiate-payment"
                ]
              },
              {
                "group": "Flutter SDK",
                "pages": [
                  "flutter-sdk/introduction"
                ]
              },
              {
                "group": "Plugins",
                "pages": [
                  "plugin/whmcs-plugin",
                  "plugin/woocommerce-plugin"
                ]
              },
              {
                "group": "Partner API",
                "pages": [
                  "guides/partner-api/introduction",
                  {
                    "group": "Merchant",
                    "pages": [
                      "guides/partner-api/merchant/create-merchant",
                      "guides/partner-api/merchant/submit-merchant-kyc",
                      "guides/partner-api/merchant/merchant-kyc-status"
                    ]
                  },
                  {
                    "group": "Payment",
                    "pages": [
                      "guides/partner-api/payment/create-payment-request",
                      "guides/partner-api/payment/create-collect-request",
                      "guides/partner-api/payment/check-payment-status"
                    ]
                  },
                  {
                    "group": "Transaction",
                    "pages": [
                      "guides/partner-api/transaction/fetch-transaction-list",
                      "guides/partner-api/transaction/fetch-settlement-list"
                    ]
                  },
                  {
                    "group": "Callback",
                    "pages": [
                      "guides/partner-api/webhook/transaction-callback",
                      "guides/partner-api/callback/settlement-callback"
                    ]
                  }
                ]
              }
            ]
          },
          {
            "tab": "API Reference",
            "groups": [
              {
                "group": "API Documentation",
                "pages": [
                  "api-reference/introduction"
                ]
              },
              {
                "group": "Endpoint Examples",
                "pages": [
                  "api-reference/endpoint/get",
                  "api-reference/endpoint/create",
                  "api-reference/endpoint/delete",
                  "api-reference/endpoint/webhook"
                ]
              }
            ]
          }
        ]
      },
      {
        "version": "V2",
        "default": true,
        "tabs": [
          {
            "tab": "Payment Gateway",
            "groups": [
              {
                "group": "Payment Page",
                "pages": [
                  {
                    "group": "Website Integration",
                    "expanded": true,
                    "pages": [
                      {
                        "group": "Standard Checkout",
                        "pages": [
                          {
                            "group": "API Integration",
                            "pages": [
                              "introduction",
                              "integration-steps",
                              {
                                "group": "API Reference",
                                "pages": [
                                  "authorization",
                                  {
                                    "group": "Create Payment",
                                    "pages": [
                                      "initiate-payment"
                                    ]
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "tab": "Payout"
          },
          {
            "tab": "Bill Payments"
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/logo_light.png",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@originpay.in"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://merchant.originpay.in"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/upitranzact",
      "github": "https://github.com/upitranzact",
      "linkedin": "https://linkedin.com/company/upitranzact"
    }
  }
}